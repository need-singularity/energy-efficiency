// n6-discriminant — n=6 판별기 (HEXA 스켈레톤)
//
// 임의 정수 n 에 대해 sigma(n)*phi(n) == n*tau(n) 성립 여부 판정.
// n=6 유일성 정리(BT-Theorem-R1)의 빠른 브루트포스 검증 도구.
// HEXA-FIRST 규칙(CLAUDE.md)에 따라 .hexa로 작성. 사용자 요청의 main.rs는 본 파일로 대체.
//
// 사용:  hexa-bin tools/n6-discriminant/main.hexa <max_n>
// 작성: 2026-04-08 / 상태: 스켈레톤 (TODO 항목 다수)

fn sigma(n: int) -> int {
    let mut s = 0
    let mut d = 1
    while d * d <= n {
        if n % d == 0 {
            s = s + d
            if d != n / d { s = s + n / d }
        }
        d = d + 1
    }
    return s
}

fn tau(n: int) -> int {
    let mut t = 0
    let mut d = 1
    while d * d <= n {
        if n % d == 0 {
            t = t + 1
            if d != n / d { t = t + 1 }
        }
        d = d + 1
    }
    return t
}

fn phi(n: int) -> int {
    let mut result = n
    let mut nn = n
    let mut p = 2
    while p * p <= nn {
        if nn % p == 0 {
            while nn % p == 0 { nn = nn / p }
            result = result - result / p
        }
        p = p + 1
    }
    if nn > 1 { result = result - result / nn }
    return result
}

fn is_n6_candidate(n: int) -> bool {
    return sigma(n) * phi(n) == n * tau(n)
}

fn main(args: list<str>) {
    let max_n = if args.len() > 1 { parse_int(args[1]) } else { 10000 }

    print("# n6-discriminant — sigma(n)*phi(n) == n*tau(n) brute force")
    print("# range: 2..=" + str(max_n))
    print("# n=6 expected unique pass (BT-Theorem-R1)")

    let mut hits = []
    let mut n = 2
    while n <= max_n {
        if is_n6_candidate(n) { hits.push(n) }
        n = n + 1
    }

    print("PASS count: " + str(hits.len()))
    for h in hits {
        print("  n = " + str(h) + "  sigma=" + str(sigma(h)) + " phi=" + str(phi(h)) + " tau=" + str(tau(h)))
    }

    // self check: n=6 정의에서 도출
    assert sigma(6) == 12   // 1+2+3+6
    assert phi(6) == 2      // {1,5}
    assert tau(6) == 4      // {1,2,3,6}
    assert is_n6_candidate(6)
    print("self-check: n=6 PASS (sigma*phi=24, n*tau=24)")
}

