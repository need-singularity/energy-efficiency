@C axis-l-5-check-2-frameworks-cite :: meta [4]
  <- axis-l-raw-117-5-check-results
  introduced_at = 2026-04-28
  origin_shard = atlas-self-arch-axis-l-axiom-cite-amendment-2026-04-28
  status = PASS
  framework_1 = "BibTeX \\cite{} reference + W3C dcterms:references for axis-L1 raw-axiom citation. CITED-AND-MOVED-ON: BibTeX cites paper-ids in a bibliography-database; atlas.n6 cites raw-N integers in a single .raw file. The IDIOM is parallel; the IMPLEMENTATION channel (LaTeX BBL vs flat-file integer-list) is atlas.n6 native."
  framework_2 = "RFC 7396 JSON Merge Patch + git revision history for axis-L2 amendment. CITED-AND-MOVED-ON: RFC 7396 specifies how JSON documents are refined via merge-patches without retraction; atlas.n6's amends body-field is the SLUG-LEVEL analogue (one row refines another row by adjacency, not by document-merge). git revision blame tracks line-level mutations via VCS; atlas.n6 chooses EXPLICIT body-field amendment to keep the @-row self-describing without requiring git context."
  framework_3 = "Append-only event sourcing (Fowler 2005) — already cited by axis-K. CITED-AND-MOVED-ON: axis-L2 EXTENDS axis-K's event-sourcing reference from BIRTH-event-only (introduced_at) to BIRTH+AMENDMENT events (introduced_at + amended_at). The append-only invariant is now type-level enforced via amends's NEVER-MUTATE-TARGET semantics."
  framework_4 = "Legal amendment-loop (US Constitution 27 amendments + parliamentary amendment procedures). CITED-AND-MOVED-ON: legal amendment is the canonical NATURAL-LANGUAGE precedent for append-only refinement-without-retraction; atlas.n6 borrows the social structure (each amendment cites the article it amends, original article stays in the document, retraction requires SECOND amendment) and applies it to @-rows."
  citation_count = 4 (exceeds the 2+ requirement; 2 frameworks for L1, 2 for L2)

