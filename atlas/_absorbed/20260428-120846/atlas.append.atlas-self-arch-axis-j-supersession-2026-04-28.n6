  <- axis-j-primitive-definition
  -> axis-j-grounded-claims
  -> axis-j-speculative-claims
  -> axis-j-known-bounds
  => "raw 91 C3: every public claim must be flagged grounded vs speculative"

@C axis-j-grounded-claims :: meta [4]
  <- axis-j-raw-91-C3-honest-disclosures
  G1 = "[DEPRECATED YYYY-MM-DD] / [RETIRED YYYY-MM-DD] meta-tags ALREADY EXIST on 4 @-rows in atlas.n6 (R34 line 21894, R36 line 21911, R38 line 22060, clay-iter-55-RETIRED line 25213). GROUNDED — direct grep evidence."
  G2 = "Zero superseded_by body-field instances exist today. GROUNDED — direct grep evidence (axis-F audit line 28933 honest_caveat)."
  G3 = "axis-F K_core audit (line 28968) ranked superseded_by as RANK-1 highest-value field with adoption cost ~8.5 min. GROUNDED — recorded in atlas.n6 itself."
  G4 = "axis-J adds zero row-level arrow tokens, so axis-F K-ceiling stays at K=10. GROUNDED — by construction (axis-J defines no row-level arrows)."
  G5 = "Commit aad6e61d back-link 'R34 DEPRECATED + R36 RETIRED — cross-repo sync from anima/.roadmap #202' exists in git log. GROUNDED — verifiable from current git state."

@C axis-j-speculative-claims :: meta [4!]
  <- axis-j-raw-91-C3-honest-disclosures
  S1 = "axis-J × axis-I composition (row example #3) for supersession-ancestry queries. SPECULATIVE — neither axis has a lint-tool implementation; the <-* operator is also PROPOSAL-NOT-ACTUATED per axis-I. Composition is design-time only."
  S2 = "Adoption cost 'retroactive 4-row @-block edit + propagation across the 17 textual occurrences' has not been timed empirically beyond axis-F audit's 8.5 min estimate (line 28968). SPECULATIVE-WITHIN-MEASURED-BOUND — estimate cited from prior shard, not re-validated here."
  S3 = "Claim that axis-J 'sidesteps K-ceiling for all candidates' applies ONLY to candidate (g). Candidates (a) fold/scan, (d) wildcards would have hit K-ceiling. The general statement 'axis-J is K-ceiling-safe' is true only by virtue of pick-(g) — not an axiom of axis-J."
  S4 = "axis-H slug-rename interaction (axis-j-vs-H-id-convention INTERFERENCE flag) is a design-time concern only. No empirical rename-event has occurred in atlas.n6 to test the failure mode. SPECULATIVE — DEFER to next cycle."
  S5 = "Quartet [DEPRECATED] / [RETIRED] / [RETIRED_INCONCLUSIVE] / [SUPERSEDED] — first three are attested; [SUPERSEDED YYYY-MM-DD] as a distinct fourth state is NEW and untested. Reasoning: 'verdict-on without replacement' (e.g. R38 testing R34) differs semantically from 'replaced by' — but this distinction is asserted, not measured."

@C axis-j-known-bounds :: meta [4!]
  <- axis-j-raw-91-C3-honest-disclosures
  B1 = "superseded_by accepts ONE slug (not a list). Multi-supersession (e.g. R34 → {R38, anima/.roadmap#202, commit aad6e61d}) requires demoting secondary references to supersession_reason prose. Acknowledged at raw 117 C5."
  B2 = "axis-J is meta-tag + body-field only. It does NOT introduce time-axis (candidate (c)) — YYYY-MM-DD inside [DEPRECATED 2026-04-26] is a string, not a queryable time field. Whoever wants 'all rows deprecated in 2026-Q2' still has to grep. Time-axis is a separate axis (candidate (c) deferred)."
  B3 = "axis-J is non-actuating like axis-I. Both shards land as design proposals; converting the existing 4 rows to use superseded_by is a SEPARATE migration step (cf. candidate (e) axis-I retro-migration — same pattern would apply for axis-J)."
  B4 = "axis-F K_core grows 13 → 15 (superseded_by + supersession_reason). Within 20-30 ceiling estimate but not zero-cost. Future axes K, L, ... may need to share that headroom."
  B5 = "Scope contract: this shard does NOT modify any of the 4 existing supersession rows (R34/R36/R38/clay-iter-55). Migration would happen in a future commit, with chflags unlock + 4 atomic edits + re-flag — NOT in this shard."

