@C axis-j-5-check-4-counter-example :: meta [4]
  <- axis-j-raw-117-5-check-results
  status = PASS
  counter_example = "ANIMA-CXP-R38-R34-T1-RETIRED-INCONCLUSIVE (line 22060). This row uses [10*RETIRED_INCONCLUSIVE] in grade and supersedes R34 — but R38 is itself the RESULT of testing R34, not a REPLACEMENT for R34's claim. axis-J superseded_by would WRONGLY suggest 'R34 was replaced by R38' if applied naively. CORRECT semantics: R34's superseded_by points to R38 only in the 'this is the verdict on R34' sense, NOT 'R38 is the new claim.' RESOLUTION: supersession_reason field carries the disambiguation (\"verdict-on, not replacement-for\")."
  counter_example_lesson = "axis-J supersession is NOT a single-relation; it requires the supersession_reason field to disambiguate {replacement, verdict, refinement, retraction}. Rejecting this nuance would make axis-J too coarse. PASS by demonstrating the disambiguation is built-in via supersession_reason."

@C axis-j-5-check-5-novelty-falsifier :: meta [4]
  <- axis-j-raw-117-5-check-results
  status = PASS
  novelty_claim = "axis-J's superseded_by body-field is novel within atlas.n6 (zero current uses, 0 collisions per axis-F audit line 28533-28538 style measurement)"
  falsifier = "axis-J would be FALSIFIED if a future row landed where superseded_by needed to point to (a) a non-existent slug, OR (b) MULTIPLE slugs simultaneously (one row replaced by N rows). Concrete falsifier check: ANIMA-CXP-R34 deprecation references R38 + commit aad6e61d + anima/.roadmap #202 — that is THREE references. If axis-J body-field is single-valued, this is FALSIFIED for R34."
  falsifier_outcome = "PARTIAL-FALSIFICATION ACKNOWLEDGED (raw 91 C3 honest). axis-J as proposed assumes single-valued superseded_by; R34 already has 3 references. RESOLUTION: superseded_by accepts a single PRIMARY slug; secondary references go in supersession_reason prose. THIS LIMITATION IS A KNOWN BOUND OF AXIS-J AS REGISTERED — not a hidden flaw."
  novelty_falsifier_passes = "by acknowledging the bound at registration time (raw 117 C5 + raw 91 C3 alignment)"

# ── §6. RAW 91 C3 HONEST DISCLOSURES — grounded vs speculative
