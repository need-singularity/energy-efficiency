  selftest_result = "OK (8 fixtures all green)"
  pass_count = 4
  warn_count = 2
  fail_count = 2
  coverage_disclosures = "Disclosure 1 covered by fixtures 1, 2, 6, 7 (meta-closure paths); Disclosure 2 covered by fixtures 1, 3, 4, 5, 8 (introduced_at paths)"
  => "★ 8 fixtures: 4 PASS, 2 WARN, 2 FAIL — both disclosures covered"

# ══════════════════════════════════════════════════════════════
## IV. RAW 117 5-CHECK + RAW 91 C3 DISCLOSURES
# ══════════════════════════════════════════════════════════════

@C atlas-metadata-policy-§IV-raw-91-C3-disclosures :: meta [4!]
  <- atlas-metadata-policy-2026-04-28-witness
  introduced_at = 2026-04-28
  origin_shard = atlas-metadata-policy-2026-04-28
  -> atlas-metadata-policy-raw-117-5-check
  -> atlas-metadata-policy-raw-91-grounded-claims
  -> atlas-metadata-policy-raw-91-speculative-claims
  -> atlas-metadata-policy-raw-91-known-bounds
  => "raw 91 C3 honest: every public claim flagged grounded vs speculative + bounds"

@C atlas-metadata-policy-raw-117-5-check :: meta [4]
  <- atlas-metadata-policy-§IV-raw-91-C3-disclosures
  introduced_at = 2026-04-28
  origin_shard = atlas-metadata-policy-2026-04-28
  C1_problem_definition = "two raw 91 C3 disclosures left open after axis-I/J actuation + axis-K registration; specifically the ENUMERATION GAP at atlas.n6 lines 28/34 and the pre-axis-K sentinel formalisation. Both disclosures are concrete + measurable."
  C1_status = "PASS"
  C2_grounded_evidence = "Disclosure 1 evidence — atlas.n6 lines 28/34/43 verbatim text + comma-count from the prose. Disclosure 2 evidence — axis-K shard line 233 falsifier_outcome explicitly names the `pre-axis-K` sentinel + 96% legacy estimate. Both disclosures have direct grep-level evidence."
  C2_status = "PASS"
  C3_honest_disclosures = "see § IV grounded/speculative/bounds rows below"
  C3_status = "PASS"
  C4_counter_example = "what if a future legitimate row carries `introduced_at = 2026-04` (year-month only)? The lint FAILs it, which is the intended behaviour — partial-date is not in the 4-form vocabulary. Counter-example for case-2 INFO: what if a row legitimately has declared==enumerated + ellipsis, e.g. `(a,b,c,...)` with declared=3? INFO is emitted, not WARN — author's explicit ellipsis is honoured."
  C4_status = "PASS"
  C5_novelty_falsifier = "novelty: this is the first content-semantics lint over atlas.n6 (companion to atlas_self_arch_axis_lint syntax lint). Falsifier (a): if >50% of post-cutover rows lack a defensible introduced_at, the cutover policy is too aggressive. Today: 12 such rows exist (the axis-K + actuation shard absorbs pre-this-shard) — manageable WARN volume. Falsifier (b): if the regex `meta-closure:\\s+(\\d+)\\s+grade-\\d+\\s+derivations\\s*\\(([^)]*)\\)` mis-matches legitimate prose, false positives appear. Today: zero false positives in atlas.n6 real-scan (only the 2 expected gap rows + silent calibration row matched). Falsifier (c): if `pre-axis-K` is later disputed as a sentinel choice (e.g. `legacy` preferred), the choice is reversible by tool/shard edit — low cost."
  C5_status = "PASS"
  five_check_summary = "5/5 PASS; falsifier (a)+(b)+(c) all bound and within tolerance"
  => "★ raw 117 5-check 5/5 PASS"

