  <- atlas-metadata-policy-§IV-raw-91-C3-disclosures
  introduced_at = 2026-04-28
  origin_shard = atlas-metadata-policy-2026-04-28
  G1 = "atlas.n6 line 28 declares 15, parens enumerate 13 names + `,...,` ellipsis. GROUNDED — direct verbatim evidence + manual comma count."
  G2 = "atlas.n6 line 34 declares 10, parens enumerate 9 names + `,...,` ellipsis. GROUNDED — same verification path."
  G3 = "atlas.n6 line 43 declares 9, parens enumerate 9 names, no ellipsis. GROUNDED — calibration row, gap=0 verified."
  G4 = "axis-K shard § raw 91 C3 falsifier_outcome explicitly resolves to `pre-axis-K` sentinel (line 233 of source shard). GROUNDED — direct quote."
  G5 = "tool/atlas_metadata_lint.hexa selftest 8/8 fixtures pass. GROUNDED — exec evidence, OK (8 fixtures) trailer."
  G6 = "tool/atlas_metadata_lint.hexa real-scan on atlas.n6 returns WARN with 14 violations (2 ENUMERATION GAP + 12 introduced_at-missing). GROUNDED — exec evidence, __ATLAS_METADATA_LINT_RESULT__ WARN trailer."
  G7 = "atlas.n6 line 43 silently passes the lint (no violation emitted for that line). GROUNDED — verified absence of `:43:` in violation list."
  G8 = "tool/atlas_self_arch_axis_lint.hexa is chflags uchg at 1065 lines (preexisting). GROUNDED — `ls -la` evidence + previous-cycle lock confirmation."
  G9 = "tool/atlas_metadata_lint.hexa is chflags uchg locked at 2026-04-28. GROUNDED — direct file_lock.hexa lock invocation evidence (audit ledger entry)."
  G10 = "this shard carries `introduced_at = 2026-04-28` on every @C row, demonstrating axis-K self-application. GROUNDED — by construction in this very file."
  => "10 grounded claims with direct evidence"

@C atlas-metadata-policy-raw-91-speculative-claims :: meta [4!]
  <- atlas-metadata-policy-§IV-raw-91-C3-disclosures
  introduced_at = 2026-04-28
  origin_shard = atlas-metadata-policy-2026-04-28
  S1 = "the 2 unnamed slots in line 28's gap and the 1 unnamed slot in line 34's gap correspond to specific named derivations. SPECULATIVE — DAG walk required to ground-truth the actual missing names; this lint does NOT walk the graph."
  S2 = "AXIS_K_CUTOFF_LINE = 35200 is the correct cutover index for all future absorptions. SPECULATIVE — file may be rebuilt/compacted, in which case the constant must be re-pinned. Today the constant is stable but not future-proof against atlas.n6 structural rewrites."
  S3 = "`pre-axis-K` sentinel literal is preferable to alternatives (`legacy`, `pre-2026-04-28`, `unset`). SPECULATIVE-WITHIN-CONVENTION — axis-K § raw 91 C3 falsifier_outcome (line 233) names `pre-axis-K` directly; this shard adopts that recommendation but reviewers may dispute the literal choice."
  S4 = "future shards will absorb introduced_at body-fields as a routine convention. SPECULATIVE — no enforcement mechanism in the absorption pipeline yet; today's adoption depends on author discipline."
  S5 = "the 12 introduced_at-missing WARNs on the axis-K + actuation shard rows will eventually be backfilled in a separate unlock+migration cycle. SPECULATIVE — no scheduled migration; depends on future review priority."
  => "5 speculative claims explicitly flagged"

@C atlas-metadata-policy-raw-91-known-bounds :: meta [4!]
  <- atlas-metadata-policy-§IV-raw-91-C3-disclosures
  introduced_at = 2026-04-28
  origin_shard = atlas-metadata-policy-2026-04-28
  B1 = "tool/atlas_metadata_lint.hexa does NOT walk the `->` DAG; it only audits prose declaration vs prose enumeration. DAG-walk audit deferred to raw 22 INFRA scope."
