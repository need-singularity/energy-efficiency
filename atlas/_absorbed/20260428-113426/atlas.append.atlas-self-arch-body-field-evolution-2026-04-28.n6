# ── (6) three highest-value intrinsic body-field gap-fillers ─
@C intrinsic_body_field_proposal_gap_analysis :: meta [4!]
  scope = "do NOT propose foreign DSL fields (confidence/verified/recheck etc.) — propose only what closes a measured GAP in existing 78 vocabulary."
  proposal_count = 3.
  honest_caveat = "proposals below are CONTENT (text), not schema mutation — schema_guard not modified by this shard; field-introduction occurs in next shard if recommendation accepted."

@R intrinsic_body_field_proposal_1_superseded_by :: meta [4!]
  proposed_type = "superseded_by = <slug>".
  gap_closed = "17 measured supersession events use [DEPRECATED]/[RETIRED] meta-tags but lack a queryable forward-pointer to the replacement entry. Today the back-link lives in commit messages (aad6e61d 'R34 DEPRECATED + R36 RETIRED — cross-repo sync from anima/.roadmap #202') — NOT in the @-block itself."
  cited_beneficiary_R_entries = ["ANIMA-CXP-R34-PHI-COEFF-EHALF [9?→DEPRECATED]", "ANIMA-CXP-R36-FORTYD-DUAL-ROUTE [9?→RETIRED]"].
  cardinality_estimate = 17 retroactive insertions + ~2-5 prospective per absorption cycle.
  faithfulness = YES (`superseded_by = <slug>` :: matches `mechanism = ...` / `binding = ...` :: 2-space-indent k=v form already in canon).
  rank_1 = "HIGHEST — closes a MEASURED gap (17 events lack body-field representation); zero ambiguity vs existing fields; aligns with [DEPRECATED]/[RETIRED] meta-tag idiom; adoption cost LOW (~17 retroactive edits @ ~30 sec each = 8.5 min)."

@R intrinsic_body_field_proposal_2_recheck_cadence :: meta [4!]
  proposed_type = "recheck_cadence = <duration>".
  gap_closed = "raw 119 temporal-decay rule fires globally but per-entry decay-budget is not body-field-encoded; today freshness lives in the trailing date or first-line measurement_date — no per-entry cadence target."
  cited_beneficiary_C_entries = ["clay-atlas-self-arch-meta-tag-evolution-witness", "clay-atlas-self-arch-body-field-evolution-witness (this shard)"].
  cited_beneficiary_R_entries = ["measured_pass_rate", "intrinsic_type_audit_2026_04_28" (snapshot rules with implicit re-measure cadence)].
  cardinality_estimate = ~30 to 60 entries (analytical [4!] shards with measurement_date already present — these have implicit cadence).
  faithfulness = YES (`recheck_cadence = 30d` :: matches `cardinality_estimate = ...` numeric-with-unit form).
  rank_2 = "MEDIUM — closes a real gap but only on the [4!] analytical tier; foundation [11*] entries are by-definition non-decaying so cadence undefined for them."
  blocker = "boundary risk: cadence on @C/@R that reference @P/[11*] axioms could imply axioms decay — must explicitly scope to non-axiomatic tiers."

@R intrinsic_body_field_proposal_3_mirrored_in :: meta [4!]
  proposed_type = "mirrored_in = <repo-path-list>".
  gap_closed = "anima cross-paradigm absorption shards (commits 1d68bb87, a9d15a0d) document atlas-anima cross-repo state in commit messages; @E type carries directed bridges (a -> b) but doesn't capture symmetric MIRROR-PRESENCE. Today cross-repo presence lives in absorption-shard prose, not as queryable field."
  cited_beneficiary_E_entries = ["anima-an14 -> n6-meta-inf-un1 (existing @E directed bridge — `mirrored_in` would be the symmetric body-field complement)"].
  cited_beneficiary_R_entries = ["anima cross-paradigm absorption R34/R35/R36 entries", "Mamba H6B / HM-B / BM3-FOLLOWUP shards"].
  cardinality_estimate = ~20 to 40 entries (cross-repo synced rules, primarily anima<->atlas axis).
  faithfulness = YES (`mirrored_in = anima/.roadmap#202, atlas/atlas.n6:R34` :: list-of-locator form already used in `cited_beneficiary_*` fields).
  rank_3 = "MARGINAL — value real but cross-repo state is already commit-message-tracked; field would duplicate. Useful only when atlas becomes queryable-as-graph independent of git history."
  blocker = "raw 22 INFRA-ONLY scope: atlas.n6 should not normatively claim presence-in-other-repos without that repo's consent — mirrored_in must be advisory, not authoritative."

