# ── (4) intrinsic limits on body-field evolution ──────────
@R intrinsic_body_field_evolution_limits :: meta [4!]
  schema_guard_cardinality_ceiling = "raw 23 _guarded_append_atlas validates @-block prefix; body-field names are NOT enumerated in any allow-list — schema_guard cost is INSENSITIVE to body-field cardinality. Parser is NOT the binding limit."
  consumer_tool_saturation_ceiling = "atlas_health, raw_audit, drill_scanner read fields by literal-string match (grep) — adding a field costs 1 grep per consumer that cares; cost is O(K_relevant) per consumer, not O(K_total). Saturation by tool-coverage not field-count."
  semantic_distinctness_ceiling = "human/agent author must remember which field to reach for; at K=78 already, 65 long-tail fields are forgotten on next shard (proven: each shard invents new fields). De-facto core ceiling ≈ 12-15 fields before AUTHORING-CONFUSION exceeds disambiguation benefit — same bound as @-type evolution found 2026-04-28."
  naming_collision_floor = "field-namespace is GLOBAL across @-types; `scope` means different things in @C-meta vs @R-procedural; collision floor = currently 0 measured but would bind if domain-specific fields colonized core names."
  self_host_fixpoint_ok = "new fields readable by grep are AUTOMATICALLY parseable by atlas_health/raw_audit/drill_scanner (they all use grep, not a typed parser) — fixpoint trivially preserved."
  foundation_axiom_invariance = "raw 24 [11*] block has NO body fields (single-line @P entries) — adding body fields to [11*] entries would VIOLATE axiom-immutability; safe path = restrict body-field extension to @C/@R [4!] meta-tier."
  honest_caveat = "all ceilings are MEASURED-PROXIES not formal proofs; semantic-distinctness ceiling judged from observed long-tail invention rate."

