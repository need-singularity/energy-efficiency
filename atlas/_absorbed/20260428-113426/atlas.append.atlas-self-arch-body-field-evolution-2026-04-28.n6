  rank_1 = "superseded_by — HIGHEST value; closes measured 17-event gap; zero ambiguity; adoption cost ~8.5 min retroactive."
  rank_2 = "recheck_cadence — MEDIUM value; closes real gap on [4!] tier; needs scope-restriction to non-axiomatic entries."
  rank_3 = "mirrored_in — MARGINAL value; duplicates commit-message state; defer until atlas becomes graph-queryable."
  recommendation = "ADOPT superseded_by in next cycle (1 new core field, K_core: 13 → 14, well within 20-30 ceiling); DEFER recheck_cadence pending [4!]-only scope-clause; SKIP mirrored_in until graph-query infrastructure exists."
  honest_status = "this shard is PROPOSAL-ONLY per task brief — no schema_guard mutation, no new body-field used in this file's own analytical entries beyond fields already attested in atlas.n6."

